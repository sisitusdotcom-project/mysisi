{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "Run Web Server (Python)",
            "url": "http://127.0.0.1:5500/index.html",
            "webRoot": "${workspaceFolder}",
            "preLaunchTask": "Start Python Server"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Open index.html (Direct File - CSS akan Error)",
            "file": "${workspaceFolder}/index.html"
        }
    ]
}